{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "title": "Auto-PR Platform",
  "uid": "auto-pr-platform",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Feedback Received (total)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "sum(feedback_received_total)",
        "legendFormat": "Total"
      }],
      "options": { "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" },
        "thresholds": { "steps": [{"color":"blue","value":null}] } } }
    },
    {
      "id": 2,
      "title": "Runs Total",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "sum(runs_total)",
        "legendFormat": "Total"
      }],
      "options": { "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" },
        "thresholds": { "steps": [{"color":"green","value":null}] } } }
    },
    {
      "id": 3,
      "title": "Failed Runs",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "sum(runs_total{status=\"FAILED\"})",
        "legendFormat": "Failed"
      }],
      "options": { "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" },
        "thresholds": { "steps": [{"color":"red","value":null}] } } }
    },
    {
      "id": 4,
      "title": "Queue Depth",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "sum(queue_depth)",
        "legendFormat": "Waiting jobs"
      }],
      "options": { "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" },
        "thresholds": { "steps": [
          {"color":"green","value":null},
          {"color":"yellow","value":5},
          {"color":"red","value":20}
        ] } } }
    },
    {
      "id": 5,
      "title": "Feedback Rate (per minute)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "rate(feedback_received_total[5m]) * 60",
        "legendFormat": "feedback/min"
      }],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } } }
    },
    {
      "id": 6,
      "title": "Run Duration (p50 / p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.50, sum(rate(run_duration_seconds_bucket[5m])) by (le, kind))",
          "legendFormat": "p50 {{kind}}"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum(rate(run_duration_seconds_bucket[5m])) by (le, kind))",
          "legendFormat": "p95 {{kind}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "palette-classic" } } }
    },
    {
      "id": 7,
      "title": "Claude Tokens (input / output)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(claude_tokens_total{type=\"input\"}[5m])",
          "legendFormat": "input tokens/s"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(claude_tokens_total{type=\"output\"}[5m])",
          "legendFormat": "output tokens/s"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } } }
    },
    {
      "id": 8,
      "title": "Runs by Status",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "sum by (kind, status) (rate(runs_total[5m]))",
        "legendFormat": "{{kind}} / {{status}}"
      }],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } } }
    }
  ]
}
