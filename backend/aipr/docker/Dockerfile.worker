# Build from backend/: docker build -f aipr/docker/Dockerfile.worker -t voyagerss-aipr-worker .
FROM node:20-slim AS base
WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl ca-certificates \
  && rm -rf /var/lib/apt/lists/*

RUN npm install -g @anthropic-ai/claude-code

FROM base AS deps
COPY aipr/package.json aipr/pnpm-workspace.yaml ./
COPY aipr/packages/config/package.json  aipr/packages/config/
COPY aipr/packages/db/package.json      aipr/packages/db/
COPY aipr/apps/worker/package.json      aipr/apps/worker/
COPY prisma/aipr.prisma                 prisma/aipr.prisma

RUN npm install -g pnpm && cd aipr && pnpm install --frozen-lockfile --prod

FROM deps AS builder
COPY aipr/packages/ aipr/packages/
COPY aipr/apps/worker/ aipr/apps/worker/
COPY prisma/aipr.prisma prisma/aipr.prisma

RUN cd aipr && pnpm --filter @repo/db run generate && pnpm --filter @repo/worker build

FROM base AS runner
WORKDIR /app

COPY --from=builder /app/aipr/node_modules              ./aipr/node_modules
COPY --from=builder /app/aipr/packages/db               ./aipr/packages/db
COPY --from=builder /app/aipr/apps/worker/dist            ./aipr/apps/worker/dist
COPY --from=builder /app/aipr/apps/worker/package.json    ./aipr/apps/worker/

ENV NODE_ENV=production

CMD ["node", "aipr/apps/worker/dist/main.js"]
