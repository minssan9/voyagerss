# Auto-PR (aipr) — copy to repo root .env or load alongside backend env
NODE_ENV=development
PORT=3010

DATABASE_URL_AIPR=mysql://root:password@localhost:3306/aipr

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

JWT_SECRET=replace_with_32+_char_random_string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_PRIVATE_KEY_BASE64=
GITHUB_WEBHOOK_SECRET=

ANTHROPIC_API_KEY=
ANTHROPIC_DAILY_COST_LIMIT_USD=10

S3_ENDPOINT=http://localhost:9000
S3_BUCKET=auto-pr-attachments
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=ap-northeast-2
S3_PUBLIC_URL=http://localhost:9000/auto-pr-attachments

WIDGET_ORIGIN_ALLOWLIST=http://localhost:9003,http://localhost:3011,http://localhost:3012
WIDGET_CDN_URL=http://localhost:4173
ADMIN_URL=http://localhost:3011
API_URL=http://localhost:3010

OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=auto-pr-api
