{
  "name": "voyagerss-aipr-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Auto-PR platform — Nest API, worker, shared packages",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter './apps/*' run dev",
    "dev:api": "pnpm --filter @repo/api run dev",
    "dev:worker": "pnpm --filter @repo/worker run dev",
    "build": "pnpm --filter './apps/*' run build",
    "test": "pnpm --filter './apps/*' run test",
    "lint": "pnpm -r run lint",
    "format": "pnpm -r run format",
    "db:migrate": "pnpm --filter @repo/db run migrate",
    "db:seed": "pnpm --filter @repo/db run seed",
    "db:generate": "pnpm --filter @repo/db run generate"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  }
}
