{
  "name": "voyagerss-backend",
  "version": "1.0.0",
  "description": "Unified backend for Voyagerss projects",
  "main": "dist/main.js",
  "scripts": {
    "start": "node dist/main.js",
    "dev": "nodemon --exec ts-node --transpile-only -r tsconfig-paths/register src/main.ts",
    "build": "tsc",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.{js,ts,json}\"",
    "generate": "prisma generate --schema=./prisma/workschd.prisma && prisma generate --schema=./prisma/investand.prisma && prisma generate --schema=./prisma/aviation.prisma && prisma generate --schema=./prisma/aipr.prisma && prisma generate --schema=./prisma/rbac.prisma",
    "generate:rbac": "prisma generate --schema=./prisma/rbac.prisma",
    "migrate:rbac": "prisma migrate dev --schema=./prisma/rbac.prisma",
    "migrate:rbac:deploy": "prisma migrate deploy --schema=./prisma/rbac.prisma",
    "seed:rbac": "ts-node -r tsconfig-paths/register prisma/seed-rbac.ts",
    "seed:aipr": "ts-node --transpile-only prisma/seed-aipr.ts",
    "postinstall": "npm run generate",
    "test": "jest",
    "collect:dart": "ts-node -r tsconfig-paths/register src/modules/investand/batch/collectDartData.ts",
    "collect:krx": "ts-node -r tsconfig-paths/register src/modules/investand/batch/collectKrxData.ts",
    "test:external": "ts-node -r tsconfig-paths/register src/modules/investand/tests/external-interface-test.ts",
    "scrape:workschd:funerals": "ts-node --transpile-only -r tsconfig-paths/register src/modules/workschd/scraper/run-scrape.ts",
    "seed:config": "ts-node -r tsconfig-paths/register src/config/seed-config.ts",
    "seed:config:force": "ts-node -r tsconfig-paths/register src/config/seed-config.ts --force",
    "seed:aipr-config": "ts-node -r tsconfig-paths/register src/config/seed-aipr-config.ts",
    "seed:aipr-config:force": "ts-node -r tsconfig-paths/register src/config/seed-aipr-config.ts --force",
    "migrate:aipr-config": "prisma db execute --file=./prisma/sql/aipr-system-config.sql --schema=./prisma/aipr.prisma",
    "seed:local": "ts-node -r tsconfig-paths/register src/config/seed-local.ts",
    "seed:local:force": "ts-node -r tsconfig-paths/register src/config/seed-local.ts --force"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.55.1",
    "@napi-rs/canvas": "^0.1.85",
    "@nestjs/common": "^11.1.24",
    "@nestjs/core": "^11.1.24",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.24",
    "@nestjs/platform-socket.io": "^11.1.24",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/websockets": "^11.1.24",
    "@octokit/app": "^14.0.2",
    "@octokit/auth-app": "^6.1.4",
    "@octokit/rest": "^20.1.2",
    "@opentelemetry/auto-instrumentations-node": "^0.48.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.52.1",
    "@opentelemetry/sdk-node": "^0.52.1",
    "@prisma/client": "^5.22.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cheerio": "^0.22.35",
    "@types/jsonwebtoken": "^9.0.10",
    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.76.8",
    "cheerio": "^1.2.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "moment-timezone": "^0.6.0",
    "mysql2": "^3.16.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.12",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "puppeteer-core": "^24.38.0",
    "reflect-metadata": "^0.2.2",
    "simple-git": "^3.36.0",
    "socket.io": "^4.8.3",
    "sqlite3": "^5.1.7",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.11.0",
    "yahoo-finance2": "^3.10.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/testing": "^11.1.24",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.27",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.5",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.7.4",
    "prisma": "^5.22.0",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  }
}
