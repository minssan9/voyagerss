# ============================================
# FRONTEND ENVIRONMENT VARIABLES (Vercel)
# Used by: Vercel deployment (VITE_ prefix only)
# Set these in: Vercel Dashboard → Project → Settings → Environment Variables
# ============================================

# Backend API URL — point to your server's public IP or domain
VITE_API_BASE_URL=https://YOUR_SERVER_IP_OR_DOMAIN:9002/api
VITE_API_URL=https://YOUR_SERVER_IP_OR_DOMAIN:9002
VITE_API_WEB=https://YOUR_SERVER_IP_OR_DOMAIN:9002

# App
VITE_APP_TITLE=Voyagerss

# Optional CDN
VITE_CDN_URL=https://cdn.example.com

# Third-party (client-side keys only)
VITE_GEMINI_API_KEY=your_gemini_api_key
VITE_KAKAO_CLIENT_ID=your_kakao_client_id
VITE_CHANNEL_TALK_PLUGIN_KEY=your_channel_talk_plugin_key
VITE_DATA_ASSEMBLY_KEY=your_data_assembly_key
VITE_DATA_PUBLIC_KEY=your_data_public_key
