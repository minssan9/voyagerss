# ============================================
# FRONTEND ENVIRONMENT VARIABLES (build-time)
# Production: set as Docker build-args in deploy-production.yml (GHCR image)
# Local dev: copy to frontend/.env or repo root .env
# ============================================

# Backend API URL (DigitalOcean — TLS at load balancer)
VITE_API_BASE_URL=https://api.voyagerss.com/api
VITE_API_URL=https://api.voyagerss.com
VITE_API_WEB=https://api.voyagerss.com

# App
VITE_APP_TITLE=Voyagerss

# Optional CDN
VITE_CDN_URL=https://cdn.example.com

# Third-party (client-side keys only)
VITE_GEMINI_API_KEY=your_gemini_api_key
VITE_KAKAO_CLIENT_ID=your_kakao_client_id
VITE_CHANNEL_TALK_PLUGIN_KEY=your_channel_talk_plugin_key
VITE_DATA_ASSEMBLY_KEY=your_data_assembly_key
VITE_DATA_PUBLIC_KEY=your_data_public_key
