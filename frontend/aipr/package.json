{
  "name": "voyagerss-aipr-frontend",
  "version": "0.1.0",
  "private": true,
  "description": "Auto-PR platform — Nuxt admin, widget apps",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter './apps/*' run dev",
    "dev:admin": "pnpm --filter @repo/admin-web run dev",
    "build": "pnpm --filter './apps/*' run build",
    "lint": "pnpm -r run lint"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  }
}
