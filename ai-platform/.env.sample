# =============================================================================
# Auto-PR Feedback Platform — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000

# -----------------------------------------------------------------------------
# Database (MySQL — 로컬 기존 서비스 사용)
# -----------------------------------------------------------------------------
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=admin
MYSQL_DATABASE=autpr_db
DATABASE_URL=mysql://root:admin@localhost:3306/autpr_db

# -----------------------------------------------------------------------------
# Cache / Queue (Redis — 로컬 기존 서비스 사용)
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# JWT Auth
# -----------------------------------------------------------------------------
JWT_SECRET=replace_with_32+_char_random_string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# -----------------------------------------------------------------------------
# GitHub App
# Register at: https://github.com/settings/apps
# Required permissions: contents:write, pull_requests:write, metadata:read
# -----------------------------------------------------------------------------
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_PRIVATE_KEY_BASE64=
GITHUB_WEBHOOK_SECRET=replace_with_random_string

# -----------------------------------------------------------------------------
# Anthropic
# Dashboard: https://console.anthropic.com
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_DAILY_COST_LIMIT_USD=10

# -----------------------------------------------------------------------------
# Storage — Presigned URL upload (S3 / MinIO)
# -----------------------------------------------------------------------------
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=auto-pr-attachments
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=ap-northeast-2
S3_PUBLIC_URL=http://localhost:9000/auto-pr-attachments

# -----------------------------------------------------------------------------
# Widget / Admin / API
# -----------------------------------------------------------------------------
WIDGET_ORIGIN_ALLOWLIST=http://localhost:*,https://*.example.com
WIDGET_CDN_URL=http://localhost:4173
ADMIN_URL=http://localhost:3001
API_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# OpenTelemetry (Phase 6)
# -----------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=auto-pr-api
