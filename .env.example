# ============================================
# LOCAL DEVELOPMENT — boot-time env only
# Copy to .env and fill in your values.
#
# Runtime settings (JWT, API keys, SMTP, CORS, etc.) are stored in DB:
#   workschd.system_config  — shared app config
#   aipr.system_config      — Auto-PR config
#
# Seed from existing .env before slimming:
#   cd backend && npm run seed:config && npm run seed:aipr-config
#
# For production, use separated files:
#   .env.backend.example  → server (DOTENV_PROD GitHub Secret)
#   .env.frontend.example → Vercel Dashboard environment variables
# ============================================

NODE_ENV=development

# Port Configuration (local npm run dev)
BACKEND_PORT=14003
FRONTEND_PORT=9003

# ============================================
# FRONTEND — build-time only (VITE_API_*)
# ============================================
VITE_API_BASE_URL=http://localhost:14003/api
VITE_API_URL=http://localhost:14003
VITE_API_WEB=http://localhost:14003
VITE_APP_TITLE=Voyagerss
# Optional
# VITE_CDN_URL=https://cdn.example.com
# VITE_I18N_LOCALE=ko

# ============================================
# BACKEND — boot-time infrastructure only
# ============================================

# Prisma Database URLs (required before DB config can load)
DATABASE_URL="mysql://user:password@localhost:3306/voyagers"
DATABASE_URL_AVIATION="mysql://user:password@localhost:3306/aviation"
DATABASE_URL_INVESTAND="mysql://user:password@localhost:3306/investand"
DATABASE_URL_WORKSCHD="mysql://user:password@localhost:3306/workschd"
DATABASE_URL_AIPR="mysql://user:password@localhost:3306/aipr"

# Encrypts secrets stored in system_config tables (workschd + aipr)
CONFIG_ENCRYPTION_KEY=replace_with_32+_char_random_string

# Redis (Bull queue / SSE — infrastructure, loaded before DB config)
REDIS_HOST=localhost
REDIS_PORT=6379

# Optional: SQLite scraper path
# SCRAPER_DB_PATH=./data/scraper.db

# ============================================
# DB-managed settings (seed via npm run seed:config)
# ============================================
# JWT_SECRET, OAuth2, SMTP, API keys (BOK/KIS/DART/GEMINI/TELEGRAM),
# CORS (FRONTEND_URL, ALLOWED_ORIGINS), Swagger URLs, logging, cache,
# rate limits, schedulers, scraper — see backend/src/config/seed-config.ts
#
# AIPR DB-managed (seed via npm run seed:aipr-config):
# JWT_SECRET, GITHUB_*, ANTHROPIC_API_KEY, S3_*, WIDGET_ORIGIN_ALLOWLIST
# — see backend/src/config/seed-aipr-config.ts
