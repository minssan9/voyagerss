# ============================================
# APPLICATION SETTINGS
# ============================================
NODE_ENV=development

# Port Configuration
# Local dev: BACKEND_PORT=14003, FRONTEND_PORT=9003
# Docker/Production: BACKEND_PORT=6172 (exposed via docker-compose)
BACKEND_PORT=14003
FRONTEND_PORT=9003

# ============================================
# DEPLOYMENT CONFIGURATION
# ============================================
# Frontend: Deployed to Vercel (set VITE_* vars in Vercel dashboard)
# Backend:  Deployed to DigitalOcean via Docker (set vars in .env.prod)

# ============================================
# FRONTEND ENVIRONMENT VARIABLES (Vercel)
# ============================================
# Set these in Vercel Project Settings → Environment Variables
# ---
# VITE_API_BASE_URL   - Backend API base (e.g. https://api.voyagerss.com/api)
# VITE_API_URL        - Backend root URL  (e.g. https://api.voyagerss.com)
# VITE_API_WEB        - Backend web URL   (e.g. https://api.voyagerss.com)
# VITE_APP_TITLE      - App title
# VITE_CDN_URL        - CDN URL for static assets (optional)
# VITE_GEMINI_API_KEY - Gemini AI API key
# VITE_DATA_ASSEMBLY_KEY  - Public data API key
# VITE_DATA_PUBLIC_KEY    - Public data API key
# VITE_CHANNEL_TALK_PLUGIN_KEY - Channel Talk plugin key
# VITE_KAKAO_CLIENT_ID         - Kakao OAuth client ID

# Local defaults (used during npm run dev)
VITE_API_BASE_URL=http://localhost:14003/api
VITE_API_URL=http://localhost:14003
VITE_API_WEB=http://localhost:14003
VITE_APP_TITLE=Voyagerss
VITE_CDN_URL=https://cdn.example.com
VITE_GEMINI_API_KEY=your_gemini_api_key_here
VITE_DATA_ASSEMBLY_KEY=your_data_assembly_key_here
VITE_DATA_PUBLIC_KEY=your_data_public_key_here
VITE_CHANNEL_TALK_PLUGIN_KEY=your_channel_talk_plugin_key_here
VITE_KAKAO_CLIENT_ID=your_kakao_client_id_here

# ============================================
# BACKEND ENVIRONMENT VARIABLES (DigitalOcean)
# ============================================

# Prisma Database URLs (Multi-Schema Support)
DATABASE_URL="mysql://user:password@localhost:3306/voyagers"
DATABASE_URL_AVIATION="mysql://user:password@localhost:3306/aviation"
DATABASE_URL_INVESTAND="mysql://user:password@localhost:3306/investand"
DATABASE_URL_WORKSCHD="mysql://user:password@localhost:3306/workschd"

# Database Configuration (Legacy - for non-Prisma connections)
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_NAME=voyagers
DATABASE_USER=root
DATABASE_PASSWORD=your_db_password
DATABASE_ACQUIRE_TIMEOUT_MILLIS=60000
DATABASE_CONNECT_TIMEOUT=60000

# Redis Configuration (optional)
# REDIS_URL=redis://localhost:6379

# Swagger Configuration
SWAGGER_DEV_URL=http://localhost:14003
SWAGGER_PROD_URL=https://api.voyagerss.com

# ============================================
# EXTERNAL SERVICES & API KEYS
# ============================================

# Bank of Korea ECOS API
BOK_API_KEY=your_bok_api_key_here

# KIS API (Korea Investment & Securities)
KIS_API_KEY=your_kis_api_key_here
KIS_API_SECRET=your_kis_api_secret_here

# DART API (Financial Supervisory Service Electronic Disclosure)
DART_API_KEY=your_dart_api_key_here

# Messaging Services
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/slack/webhook

# AI API Keys
GEMINI_API_KEY=your_gemini_api_key_here
# CLAUDE_API_KEY=your_claude_api_key_here

# ============================================
# EMAIL CONFIGURATION
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# ============================================
# CORS & SECURITY SETTINGS
# ============================================
# FRONTEND_URL: Primary frontend origin (Vercel production URL)
FRONTEND_URL=http://localhost:9003

# ALLOWED_ORIGINS: Comma-separated list of allowed CORS origins
# Production example: https://voyagerss.vercel.app,https://www.voyagerss.com
# All *.vercel.app subdomains are auto-allowed for preview deployments
ALLOWED_ORIGINS=http://localhost:9003,http://localhost:5173,http://localhost:3000

# Rate Limiting
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX_REQUESTS=100

# Security
JWT_SECRET=your_jwt_secret_here_change_in_production

# ============================================
# DATA COLLECTION & SCHEDULER
# ============================================
ENABLE_SCHEDULER=true
SCHEDULER_TIMEZONE=Asia/Seoul
DATA_COLLECTION_CRON="0 16 * * 1-5"
WEEKEND_DATA_COLLECTION=false

# ============================================
# LOGGING & CACHE
# ============================================
LOG_LEVEL=info
LOG_FILE_PATH=./logs/app.log
CACHE_TTL_MINUTES=60
ENABLE_CACHE=true
