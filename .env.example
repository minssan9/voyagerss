# ============================================
# LOCAL DEVELOPMENT — all-in-one env file
# Copy to .env and fill in your values.
#
# For production, use separated files:
#   .env.backend.example  → server (DOTENV_PROD GitHub Secret)
#   .env.frontend.example → Vercel Dashboard environment variables
# ============================================
NODE_ENV=development
# Port Configuration
# Local environment (npm run dev) uses these ports
BACKEND_PORT=14003
FRONTEND_PORT=9003

# Dev/Docker environment maps these to 6172 and 6171 respectively.
# Docker Frontend: http://localhost:6171 (mapped from internal 80)
# Docker Backend: http://localhost:6172 (mapped from internal 14003)

# ============================================
# FRONTEND ENVIRONMENT VARIABLES
# ============================================
# API Configuration (Default for Local)
# Production (Docker / GHCR): https://api.voyagerss.com — see .env.frontend.example
VITE_API_BASE_URL=http://localhost:14003/api
VITE_API_URL=http://localhost:14003
VITE_API_WEB=http://localhost:14003
VITE_APP_TITLE=Voyagerss

# CDN Configuration (optional, for hosting static assets)
VITE_CDN_URL=https://cdn.example.com

# Gemini AI API
VITE_GEMINI_API_KEY=your_gemini_api_key_here


# ============================================
# BACKEND ENVIRONMENT VARIABLES
# ============================================

# Prisma Database URLs (Multi-Schema Support)
# Main database
DATABASE_URL="mysql://user:password@localhost:3306/voyagers"
# Module-specific databases
DATABASE_URL_AVIATION="mysql://user:password@localhost:3306/aviation"
DATABASE_URL_INVESTAND="mysql://user:password@localhost:3306/investand"
DATABASE_URL_WORKSCHD="mysql://user:password@localhost:3306/workschd"
# Auto-PR platform (Nest API / worker — backend/aipr)
DATABASE_URL_AIPR="mysql://user:password@localhost:3306/aipr"

# Database Configuration (Legacy - for non-Prisma connections)
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_NAME=voyagers
DATABASE_USER=root
DATABASE_PASSWORD=your_db_password
DATABASE_ACQUIRE_TIMEOUT_MILLIS=60000
DATABASE_CONNECT_TIMEOUT=60000

# Redis Configuration (optional)
# REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# Auto-PR (aipr) — see backend/aipr/.env.sample
AIPR_API_PORT=3010
JWT_SECRET_AIPR=replace_with_32+_char_random_string
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_BASE64=
GITHUB_WEBHOOK_SECRET=
ANTHROPIC_API_KEY=
WIDGET_ORIGIN_ALLOWLIST=http://localhost:9003,http://localhost:3011
ADMIN_URL=http://localhost:3011
API_URL=http://localhost:3010

# Swagger Configuration
SWAGGER_DEV_URL=http://localhost:14003
SWAGGER_PROD_URL=https://api.voyagerss.com

# ============================================
# EXTERNAL SERVICES & API KEYS
# ============================================

# Bank of Korea ECOS API
BOK_API_KEY=your_bok_api_key_here

# KIS API (Korea Investment & Securities)
KIS_API_KEY=your_kis_api_key_here
KIS_API_SECRET=your_kis_api_secret_here

# DART API (Financial Supervisory Service Electronic Disclosure)
DART_API_KEY=your_dart_api_key_here

# Messaging Services
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/slack/webhook

# AI API Keys
GEMINI_API_KEY=your_gemini_api_key_here
# CLAUDE_API_KEY=your_claude_api_key_here

# Public Data API Keys
VITE_DATA_ASSEMBLY_KEY=your_data_assembly_key_here
VITE_DATA_PUBLIC_KEY=your_data_public_key_here
# Third-Party Services
VITE_CHANNEL_TALK_PLUGIN_KEY=your_channel_talk_plugin_key_here
VITE_KAKAO_CLIENT_ID=your_kakao_client_id_here


# ============================================
# EMAIL CONFIGURATION
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# CORS & SECURITY SETTINGS
# ============================================
# Public backend URL (needed when frontend is on Vercel — set to your public IP or domain)
# Local: http://localhost:14003  |  Production: https://api.voyagerss.com
BACKEND_PUBLIC_URL=http://localhost:14003

FRONTEND_URL=http://localhost:9003
# Production: FRONTEND_URL=https://voyagerss.com
ALLOWED_ORIGINS=http://localhost:9003,http://localhost:6171,http://localhost:14003,https://voyagerss.com,https://api.voyagerss.com
CORS_ENABLED=true
HELMET_ENABLED=true

# Rate Limiting
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX_REQUESTS=100

# Security
JWT_SECRET=your_jwt_secret_here_change_in_production

# ============================================
# DATA COLLECTION & SCHEDULER
# ============================================
ENABLE_SCHEDULER=true
SCHEDULER_TIMEZONE=Asia/Seoul
DATA_COLLECTION_CRON="0 16 * * 1-5"
WEEKEND_DATA_COLLECTION=false

# Workschd funeral scraper scheduler (disabled by default)
WORKSCHD_SCRAPER_ENABLED=false
WORKSCHD_SCRAPER_CRON="*/30 * * * *"
# Optional JSON map for per-home listing URL overrides
# Example: {"인천적십자병원 장례식장":"https://new-domain.example/funeral/list"}
WORKSCHD_SCRAPER_LISTING_URL_OVERRIDES_JSON=

# ============================================
# LOGGING & CACHE
# ============================================
LOG_LEVEL=info
LOG_FILE_PATH=${BASE_PATH}/logs/app.log
CACHE_TTL_MINUTES=60
ENABLE_CACHE=true
