# ============================================
# Voyagerss — Production environment template
# Copy to .env on server (GitHub Secret: DOTENV_PROD)
#
# Runtime settings (JWT, OAuth, API keys, SMTP, CORS, schedulers)
# are stored in DB after first seed:
#   workschd.system_config  — shared app config
#   aipr.system_config      — Auto-PR config
#
# Seed once from a full backup:
#   cd backend && npm run seed:config && npm run seed:aipr-config
# ============================================

NODE_ENV=production

# ── Backend boot-time (Docker / PM2) ─────────────────────
BACKEND_PORT=9002
# Docker on droplet: leave 0.0.0.0 (default). Bare PM2 behind local nginx: 127.0.0.1
# BACKEND_HOST=127.0.0.1

# Prisma Database URL (shared by all modules: workschd, investand, aviation, aipr, rbac)
DATABASE_URL="mysql://user:password@db-host:3306/voyagers"

# Encrypts secrets stored in system_config tables (workschd + aipr)
CONFIG_ENCRYPTION_KEY=replace_with_32+_char_random_string

# Redis (Bull queue / SSE — infrastructure, loaded before DB config)
REDIS_HOST=localhost
REDIS_PORT=6379

# Optional: SQLite scraper path
SCRAPER_DB_PATH=./data/scraper.db

# ── Frontend build-time (Docker build-args / Vite production) ───
VITE_API_BASE_URL=https://api.voyagerss.com/api
VITE_API_URL=https://api.voyagerss.com
VITE_API_WEB=https://api.voyagerss.com
VITE_APP_TITLE=Voyagerss
# Optional
# VITE_CDN_URL=https://cdn.example.com
# VITE_I18N_LOCALE=ko

# ── Docker Compose only (droplet pull — NOT in DOTENV_PROD secret) ───
# GITHUB_OWNER=your-github-owner
# IMAGE_TAG=latest

# ── DB-managed settings (seed via npm run seed:config) ───
# JWT_SECRET, OAuth2, SMTP, API keys (BOK/KIS/DART/GEMINI/TELEGRAM),
# CORS (FRONTEND_URL, ALLOWED_ORIGINS), Swagger URLs, logging, cache,
# rate limits, schedulers, scraper — see backend/src/config/seed-config.ts
#
# AIPR DB-managed (seed via npm run seed:aipr-config):
# JWT_SECRET, GITHUB_*, ANTHROPIC_API_KEY, S3_*, WIDGET_ORIGIN_ALLOWLIST,
# AIPR_AGENT_PROVIDER, AIPR_OMP_MODEL — see backend/src/config/seed-aipr-config.ts

# ============================================
# Local development overrides (copy to .env.local)
# ============================================
# NODE_ENV=development
# BACKEND_PORT=14003
# FRONTEND_PORT=9003
# DATABASE_URL="mysql://root:password@127.0.0.1:3306/voyagers"
# VITE_API_BASE_URL=http://localhost:14003/api
# VITE_API_URL=http://localhost:14003
# VITE_API_WEB=http://localhost:14003
#
# Local MLX + oh-my-pi for Auto-PR (Apple Silicon):
#   ~/repository/local-llm/mlx/setup.sh && MLX_PROFILE=coding ~/repository/local-llm/mlx/start-server.sh
# AIPR_AGENT_PROVIDER=omp_sdk
# AIPR_OMP_MODEL=mlx-local/qwen3-coder-local
# AIPR_OMP_THINKING_LEVEL=off
# AIPR_OMP_MAX_TURNS=40
#
# Local Open WebUI (Docker): http://localhost:3000
#   ~/repository/local-llm/openwebui/start.sh (requires MLX on :8080)
