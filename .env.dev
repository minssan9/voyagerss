# CORS & SECURITY SETTINGS
# ============================================
FRONTEND_URL=http://local.voyagerss.com:6171
ALLOWED_ORIGINS=http://local.voyagerss.com:6171,http://local.voyagerss.com:9003,http://local.voyagerss.com:6172
CORS_ENABLED=true
HELMET_ENABLED=true

# Rate Limiting
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX_REQUESTS=100

# Security
JWT_SECRET=your_jwt_secret_here_change_in_production

# ============================================
# DATA COLLECTION & SCHEDULER
# ============================================
ENABLE_SCHEDULER=true
SCHEDULER_TIMEZONE=Asia/Seoul
DATA_COLLECTION_CRON="0 16 * * 1-5"
WEEKEND_DATA_COLLECTION=false

# ============================================
# LOGGING & CACHE
# ============================================
LOG_LEVEL=info
LOG_FILE_PATH=/app/logs/app.log
CACHE_TTL_MINUTES=60
ENABLE_CACHE=true
