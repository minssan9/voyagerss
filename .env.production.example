# ============================================
# PRODUCTION ENVIRONMENT (.env.production)
# ============================================
# Copy this file to .env on your EC2 instance and fill in real values.
# For Vercel frontend, set VITE_* variables in the Vercel dashboard.

NODE_ENV=production

# ============================================
# PORT CONFIGURATION
# ============================================
BACKEND_PORT=9002

# ============================================
# FRONTEND (Vercel) — set these in Vercel Dashboard > Settings > Environment Variables
# ============================================
# VITE_API_BASE_URL=https://api.yourdomain.com/api
# VITE_API_URL=https://api.yourdomain.com
# VITE_API_WEB=https://api.yourdomain.com
# VITE_APP_TITLE=Voyagerss
# VITE_GEMINI_API_KEY=your_gemini_api_key

# ============================================
# DATABASE (AWS RDS MySQL)
# ============================================
DATABASE_URL="mysql://username:password@your-rds-endpoint.rds.amazonaws.com:3306/voyagers"
DATABASE_URL_AVIATION="mysql://username:password@your-rds-endpoint.rds.amazonaws.com:3306/aviation"
DATABASE_URL_INVESTAND="mysql://username:password@your-rds-endpoint.rds.amazonaws.com:3306/investand"
DATABASE_URL_WORKSCHD="mysql://username:password@your-rds-endpoint.rds.amazonaws.com:3306/workschd"

# ============================================
# SECURITY
# ============================================
JWT_SECRET=your_strong_production_jwt_secret_here
CORS_ENABLED=true
HELMET_ENABLED=true
FRONTEND_URL=https://yourdomain.com
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Rate Limiting
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# EXTERNAL SERVICES
# ============================================
BOK_API_KEY=your_bok_api_key
KIS_API_KEY=your_kis_api_key
KIS_API_SECRET=your_kis_api_secret
DART_API_KEY=your_dart_api_key
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
GEMINI_API_KEY=your_gemini_api_key

# ============================================
# EMAIL (SMTP)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password

# ============================================
# SCHEDULER
# ============================================
ENABLE_SCHEDULER=true
SCHEDULER_TIMEZONE=Asia/Seoul
DATA_COLLECTION_CRON="0 16 * * 1-5"
WEEKEND_DATA_COLLECTION=false

# Workschd Scraper
WORKSCHD_SCRAPER_ENABLED=false
WORKSCHD_SCRAPER_CRON="*/30 * * * *"

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
LOG_FILE_PATH=/home/ec2-user/voyagerss/logs/app.log
CACHE_TTL_MINUTES=60
ENABLE_CACHE=true

# ============================================
# SWAGGER (disable in production or restrict)
# ============================================
SWAGGER_PROD_URL=https://api.yourdomain.com
