# ============================================
# APPLICATION SETTINGS
# ============================================
NODE_ENV=development
PORT=9002

# ============================================
# FRONTEND ENVIRONMENT VARIABLES (bootstrap only — must be in .env)
# ============================================
VITE_API_BASE_URL=http://localhost:9002/api
VITE_API_URL=http://localhost:9002
VITE_API_WEB=http://localhost:9002
VITE_APP_TITLE=Voyagerss

# ============================================
# VITE API KEYS → MOVED TO workschd.system_config (category=frontend)
# Run: npx prisma db execute --file=./backend/prisma/sql/seed-frontend-config.sql --schema=./backend/prisma/workschd.prisma
# Served via: GET /api/workschd/config/public (no auth)
# ============================================
# VITE_CDN_URL / VITE_GEMINI_API_KEY
# VITE_KAKAO_CLIENT_ID / VITE_CHANNEL_TALK_PLUGIN_KEY
# VITE_DATA_ASSEMBLY_KEY / VITE_DATA_PUBLIC_KEY

# ============================================
# BACKEND ENVIRONMENT VARIABLES
# ============================================
BACKEND_PORT=9002
FRONTEND_PORT=9003

# Prisma Database URLs (Multi-Schema Support)
DATABASE_URL="mysql://root:admin@localhost:3306/voyagers"
DATABASE_URL_AVIATION="mysql://root:admin@localhost:3306/aviation"
DATABASE_URL_INVESTAND="mysql://root:admin@localhost:3306/investand"
DATABASE_URL_WORKSCHD="mysql://root:admin@localhost:3306/workschd"

# Database Configuration (Legacy)
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_NAME=voyagers
DATABASE_USER=root
DATABASE_PASSWORD=admin
DATABASE_ACQUIRE_TIMEOUT_MILLIS=60000
DATABASE_CONNECT_TIMEOUT=60000

# Redis Configuration
# REDIS_URL=redis://local.voyagerss.com:6379

# Config encryption key (needed to decrypt sensitive keys stored in system_config)
# CONFIG_ENCRYPTION_KEY=change-me-in-production

# ============================================
# KEYS BELOW → MOVED TO workschd.system_config
# Run: npx ts-node src/config/seed-config.ts
# ============================================
# SWAGGER_DEV_URL / SWAGGER_PROD_URL
# BOK_API_KEY / KIS_API_KEY / KIS_API_SECRET / DART_API_KEY
# TELEGRAM_BOT_TOKEN / SLACK_WEBHOOK_URL
# GEMINI_API_KEY / CLAUDE_API_KEY
# SMTP_HOST / SMTP_PORT / SMTP_USER / SMTP_PASS
# FRONTEND_URL / ALLOWED_ORIGINS / CORS_ENABLED / HELMET_ENABLED / BASE_PATH
# API_RATE_LIMIT_WINDOW_MS / API_RATE_LIMIT_MAX_REQUESTS / JWT_SECRET
# ENABLE_SCHEDULER / SCHEDULER_TIMEZONE / DATA_COLLECTION_CRON / WEEKEND_DATA_COLLECTION
# LOG_LEVEL / LOG_FILE_PATH / ENABLE_CACHE / CACHE_TTL_MINUTES