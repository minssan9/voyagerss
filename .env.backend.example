# ============================================
# BACKEND ENVIRONMENT VARIABLES — boot-time only
# Used by: Docker container on server (deploy/docker-compose.prod.yml)
# GitHub Secret: DOTENV_PROD
#
# Runtime settings: seed once from full .env backup, then manage via:
#   POST /api/workschd/admin/config  (workschd DB)
#   /aipr/admin/config               (aipr DB)
# ============================================

NODE_ENV=production
BACKEND_PORT=9002
# Docker on droplet: leave 0.0.0.0 (default). Bare PM2 behind local nginx: 127.0.0.1
# BACKEND_HOST=127.0.0.1

# ── Databases (Prisma — required at boot) ───
DATABASE_URL="mysql://user:password@db-host:3306/voyagers"
DATABASE_URL_AVIATION="mysql://user:password@db-host:3306/aviation"
DATABASE_URL_INVESTAND="mysql://user:password@db-host:3306/investand"
DATABASE_URL_WORKSCHD="mysql://user:password@db-host:3306/workschd"
DATABASE_URL_AIPR="mysql://user:password@db-host:3306/aipr"

# ── Config encryption (workschd + aipr system_config) ───
CONFIG_ENCRYPTION_KEY=replace_with_32+_char_random_string

# ── Redis (infrastructure) ─────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── SQLite (scraper, optional) ─────────────
SCRAPER_DB_PATH=./data/scraper.db

# All other settings (JWT, OAuth, SMTP, API keys, CORS, schedulers)
# live in DB — run: npm run seed:config && npm run seed:aipr-config
